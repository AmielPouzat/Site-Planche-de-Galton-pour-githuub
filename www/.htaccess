RewriteEngine On

RewriteCond %{ENV:HTTPS} !on
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical URLs without .html
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Serve existing .html files when the extensionless URL is requested.
RewriteRule ^atelier/?$ outils.html [L]
RewriteRule ^interpolation/?$ regression.html [L]
RewriteRule ^galton/?$ galton.html [L]
RewriteRule ^coffre/?$ coffre.html [L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ $1.html [L]
